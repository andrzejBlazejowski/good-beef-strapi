{
  "kind": "collectionType",
  "collectionName": "recommended_products",
  "info": {
    "singularName": "recommended-product",
    "pluralName": "recommended-products",
    "displayName": "Recommended Product",
    "description": "Retail product card in the recommended products section"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "priceLabel": {
      "type": "string",
      "required": true
    },
    "priceSyncedAt": {
      "type": "datetime"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "imageAlt": {
      "type": "string"
    },
    "shopUrl": {
      "type": "string",
      "required": true
    },
    "lightboxImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "buyButtonLabel": {
      "type": "string",
      "default": "Kup teraz"
    },
    "showBuyButton": {
      "type": "boolean",
      "default": true
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
