{
  "kind": "collectionType",
  "collectionName": "stat_counters",
  "info": {
    "singularName": "stat-counter",
    "pluralName": "stat-counters",
    "displayName": "Stat Counter",
    "description": "Animated statistic in the fact counter section"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "value": {
      "type": "integer",
      "required": true
    },
    "label": {
      "type": "string",
      "required": true
    },
    "animationFrom": {
      "type": "integer",
      "default": 1
    },
    "animationTo": {
      "type": "integer"
    },
    "animationSpeed": {
      "type": "integer",
      "default": 5000
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
