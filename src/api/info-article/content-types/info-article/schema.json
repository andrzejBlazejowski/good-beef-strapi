{
  "kind": "collectionType",
  "collectionName": "info_articles",
  "info": {
    "singularName": "info-article",
    "pluralName": "info-articles",
    "displayName": "Info Article",
    "description": "Information section card (shipping, slaughter process, etc.)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "imageAlt": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
