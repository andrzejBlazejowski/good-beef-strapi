  "infoArticles": [
    {
      "title": "Jak kupić wołowine premium?",
      "content": "Aby zapewnić możliwość zakupu naszych produktów szerszej grupie odbiorców, wprowadziliśmy sprzedaż wysyłkową. Mięso w celu wysyłki jest zapakowane w opakowanie typu termobox ze specjalnym wkładem chłodzącym. Koszt wysyłki przy zamówieniu do kwoty 1000zł kosztuje jedynie 40zł, powyżej 1000zł przesyłka jest darmowa. Nasze produkty mogą Państwo również zakupić na terenie Zakładu w Stramnicy nr 32.",
      "image": "blog/paczka_590x270.jpg",
      "imageAlt": "zdjęcie paczki",
      "order": 1
    },
    {
      "title": "Odpowiedni proces, kluczem do jakości i bezpieczeństwa",
      "content": "Ubój odbywa się w zaprzyjaźnionej ubojni, dokąd zwierzęta przewożone są własnym transportem z gospodarstwa w Stramnicy. Kolejnego dnia półtusze są przewożone do zakładu rozbioru w Stramnicy. W celu zapewnienia produkcji wysokiej jakości, zakład posiada wdrożony system HACCP.",
      "image": "blog/cuting_meat_590x270.jpg",
      "imageAlt": "krojenie kawałka wołowiny",
      "order": 2
    }
  ],
