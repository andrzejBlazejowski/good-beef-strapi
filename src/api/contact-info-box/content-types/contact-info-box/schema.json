{
  "kind": "collectionType",
  "collectionName": "contact_info_boxes",
  "info": {
    "singularName": "contact-info-box",
    "pluralName": "contact-info-boxes",
    "displayName": "Contact Info Box",
    "description": "Contact detail box (address, phone, email)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "type": {
      "type": "enumeration",
      "enum": ["address", "phone", "email"],
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "link": {
      "type": "string"
    },
    "iconClass": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
